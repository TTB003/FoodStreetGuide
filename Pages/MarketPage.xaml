<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodStreetGuide.Pages.MarketPage"
             Title="Market">

    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="12">
            <Image x:Name="HeaderImage" HeightRequest="200" Aspect="AspectFill" />

            <Label x:Name="MarketName" FontSize="24" FontAttributes="Bold" />
            <Label x:Name="MarketAddress" FontSize="14" TextColor="#666" />
            <Label x:Name="MarketHours" FontSize="14" TextColor="#666" />

            <Label Text="About" FontAttributes="Bold" FontSize="18" Margin="0,8" />
            <Label x:Name="MarketDescription" FontSize="14" />

            <Label Text="Các quầy / khu vực" FontAttributes="Bold" FontSize="18" Margin="0,12" />
            <CollectionView x:Name="StallsView" ItemsLayout="VerticalList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame CornerRadius="8" HasShadow="True" Margin="0,6">
                            <VerticalStackLayout Padding="8">
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding Description}" FontSize="12" LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
