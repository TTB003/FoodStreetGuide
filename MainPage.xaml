<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodStreetGuide.MainPage">

    <ScrollView>
        <VerticalStackLayout Spacing="12">

            <!-- Hero banner with background image and overlay text + actions -->
            <Grid HeightRequest="220">
                <Image Source="images/banner.jpg" Aspect="AspectFill" />
                <BoxView BackgroundColor="#80000000" />
                <VerticalStackLayout Padding="16" VerticalOptions="Center">
                    
                    <Label Text="Đồ án" TextColor="White" FontSize="28" FontAttributes="Bold" />
                    <HorizontalStackLayout Spacing="12" Margin="0,12,0,0">
                        <Button Text="LISTEN" BackgroundColor="#D81B60" TextColor="White" CornerRadius="8" HeightRequest="44" />
                        <Button Text="CREATE" BackgroundColor="#222" TextColor="White" CornerRadius="8" HeightRequest="44" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Grid>

            <!-- Section title -->
            <Label Text="For You" FontAttributes="Bold" FontSize="18" Margin="12,8" />

            <!-- Horizontal carousel showing only the market -->
            <CollectionView x:Name="PlacesView" ItemsLayout="HorizontalList" HeightRequest="220" Margin="8,0"
                            SelectionMode="Single" SelectionChanged="OnPlaceSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame WidthRequest="300" HeightRequest="200" CornerRadius="12" HasShadow="True" Padding="0" Margin="6">
                            <Grid>
                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                <BoxView BackgroundColor="#55000000" />
                                <VerticalStackLayout Padding="12" VerticalOptions="End">
                                    <Label Text="{Binding Name}" TextColor="White" FontAttributes="Bold" />
                                    <Label Text="{Binding Description}" TextColor="#DDDDDD" LineBreakMode="TailTruncation" MaxLines="2" FontSize="12" />
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Spacer / footer -->
            <BoxView HeightRequest="24" Color="Transparent" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
